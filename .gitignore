# ---------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# ---------------------------------------------------------------------------
# Jupyter Notebook
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Data files - keep folder structure but ignore large/raw data.
# Raw data is supplied locally (see README). Keep the data dictionary tracked.
# ---------------------------------------------------------------------------
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/*.txt

# ---------------------------------------------------------------------------
# Tableau extract CSVs are generated from the pipeline; ignore the data
# but keep the workbooks (.twbx) and folder structure tracked.
# ---------------------------------------------------------------------------
tableau/extracts/*
!tableau/extracts/.gitkeep

# Generic large/tabular data formats
*.csv
*.xlsx
*.xls
*.parquet
*.feather
*.h5

# ---------------------------------------------------------------------------
# Trained models / serialized artifacts
# ---------------------------------------------------------------------------
models/*
!models/.gitkeep
*.pkl
*.joblib

# ---------------------------------------------------------------------------
# Generated visualizations (regenerated from notebooks)
# ---------------------------------------------------------------------------
visualizations/*
!visualizations/.gitkeep

# ---------------------------------------------------------------------------
# Tableau temp / backup files
# ---------------------------------------------------------------------------
*.twb.bak
*.hyper
~*.twb

# ---------------------------------------------------------------------------
# IDE / editor / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs & temp
# ---------------------------------------------------------------------------
*.log
.cache/
tmp/
